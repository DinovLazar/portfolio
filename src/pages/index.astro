---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio">
  <section
    id="home"
    class="min-h-screen scroll-mt-24 flex items-center justify-center px-6"
  >
    <div class="max-w-3xl w-full">
      <p class="text-accent text-xs sm:text-sm font-medium tracking-[0.2em] uppercase mb-5">
        Welcome
      </p>
      <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-bold leading-[1.05] tracking-tight">
        Hello &mdash; I'm <span class="text-accent">building something</span> here.
      </h1>
      <p class="mt-6 text-base sm:text-lg text-muted max-w-xl leading-relaxed">
        Placeholder content. The home section will introduce who you are
        and what you do.
      </p>
    </div>
  </section>

  <section
    id="projects"
    class="min-h-screen scroll-mt-24 flex items-center justify-center px-6"
  >
    <div class="max-w-3xl w-full">
      <p class="text-accent text-xs sm:text-sm font-medium tracking-[0.2em] uppercase mb-5">
        Selected work
      </p>
      <h2 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.05] tracking-tight">
        Projects
      </h2>
      <p class="mt-6 text-base sm:text-lg text-muted max-w-xl leading-relaxed">
        Project cards will live here. The active-nav indicator should switch
        to the green dot beside &ldquo;Projects&rdquo; while you're in this section.
      </p>
    </div>
  </section>

  <section
    id="contact"
    class="min-h-screen scroll-mt-24 flex items-center justify-center px-6"
  >
    <div class="max-w-3xl w-full">
      <p class="text-accent text-xs sm:text-sm font-medium tracking-[0.2em] uppercase mb-5">
        Get in touch
      </p>
      <h2 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.05] tracking-tight">
        Contact
      </h2>
      <p class="mt-6 text-base sm:text-lg text-muted max-w-xl leading-relaxed">
        Contact form, email, or social links go here.
      </p>
    </div>
  </section>
</Layout>
