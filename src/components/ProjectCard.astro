---
interface Props {
  name: string;
  description: string;
  status: string;
  githubUrl: string;
  liveUrl?: string;
  image: string;
}

const { name, description, status, githubUrl, liveUrl, image } = Astro.props;
---

<article
  class="group flex flex-col bg-[#1a1a1a] border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 ease-out hover:bg-[#1f1f1f] hover:border-white/20 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/50"
>
  <div
    class="relative aspect-[16/10] overflow-hidden bg-gradient-to-br from-accent/[0.08] via-[#1a1a1a] to-[#0f0f0f]"
  >
    <img
      src={image}
      alt={`${name} screenshot`}
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover opacity-0 transition-all duration-500 ease-out group-hover:scale-[1.02]"
      onload="this.style.opacity='1'"
      onerror="this.style.opacity='0'"
    />
  </div>

  <div class="flex flex-col flex-1 p-6">
    <h3 class="font-display text-2xl font-semibold tracking-tight">
      {name}
    </h3>
    <p class="mt-1.5 text-sm text-muted">{status}</p>
    <p class="mt-4 text-base text-muted leading-relaxed flex-1">
      {description}
    </p>

    <div class="mt-6 flex items-center justify-end gap-2">
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${name} GitHub repository`}
        class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-white/[0.04] border border-white/10 text-fg hover:text-accent hover:border-white/20 hover:bg-white/[0.08] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="16 18 22 12 16 6" />
          <polyline points="8 6 2 12 8 18" />
        </svg>
      </a>
      {
        liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${name} live site`}
            class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-white/[0.04] border border-white/10 text-fg hover:text-accent hover:border-white/20 hover:bg-white/[0.08] transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M7 7h10v10" />
              <path d="M7 17 17 7" />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</article>
