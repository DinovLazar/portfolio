---
const githubUrl = 'https://github.com/DinovLazar';
const emailUrl = 'mailto:dinovlazar2011@gmail.com';
---

<div class="relative pt-24 sm:pt-32 pb-8 sm:pb-12 px-6">
  <div class="mx-auto max-w-6xl w-full">
    <p class="text-accent text-xs sm:text-sm font-medium tracking-[0.2em] uppercase mb-6 sm:mb-8">
      Hi, I'm Lazar Dinov
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 items-end">
      <h1
        class="lg:col-span-7 font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight"
      >
        Full-Stack
        <br />
        Developer
      </h1>

      <p class="lg:col-span-5 text-base sm:text-lg text-muted leading-relaxed">
        Transforming business ideas into scalable,
        <span class="text-accent font-medium">full-stack</span>
        digital products with modern technologies and clean architecture.
      </p>
    </div>

    <div class="mt-8 sm:mt-10 flex items-center gap-3">
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
        class="inline-flex items-center justify-center h-11 w-11 rounded-xl bg-white/[0.04] border border-white/10 text-fg hover:text-accent hover:border-white/20 hover:bg-white/[0.06] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          />
          <path d="M9 18c-4.51 2-5-2-7-2" />
        </svg>
      </a>
      <a
        href={emailUrl}
        aria-label="Email Lazar"
        class="inline-flex items-center justify-center h-11 w-11 rounded-xl bg-white/[0.04] border border-white/10 text-fg hover:text-accent hover:border-white/20 hover:bg-white/[0.06] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </a>
    </div>
  </div>
</div>
