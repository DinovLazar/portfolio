---
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
---

<form id="contact-form" class="space-y-4">
  <input type="hidden" name="access_key" value={accessKey} />
  <input type="hidden" name="subject" value="New message from portfolio" />
  <input type="hidden" name="from_name" value="Portfolio Contact Form" />
  <input
    type="checkbox"
    name="botcheck"
    class="hidden"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />

  <div>
    <label for="name" class="block text-sm font-medium mb-2 text-fg">
      Name
    </label>
    <input
      id="name"
      name="name"
      type="text"
      required
      autocomplete="name"
      placeholder="Your name"
      class="w-full px-4 py-3 rounded-lg bg-[#1a1a1a] border border-white/10 text-fg placeholder:text-muted/60 focus:border-accent/60 focus:outline-none focus:ring-2 focus:ring-accent/30 transition-colors"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium mb-2 text-fg">
      Email
    </label>
    <input
      id="email"
      name="email"
      type="email"
      required
      autocomplete="email"
      placeholder="you@example.com"
      class="w-full px-4 py-3 rounded-lg bg-[#1a1a1a] border border-white/10 text-fg placeholder:text-muted/60 focus:border-accent/60 focus:outline-none focus:ring-2 focus:ring-accent/30 transition-colors"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-medium mb-2 text-fg">
      Message
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      placeholder="What's on your mind?"
      class="w-full px-4 py-3 rounded-lg bg-[#1a1a1a] border border-white/10 text-fg placeholder:text-muted/60 focus:border-accent/60 focus:outline-none focus:ring-2 focus:ring-accent/30 transition-colors resize-y min-h-[140px]"
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full py-3 rounded-lg bg-accent hover:bg-accent/90 text-bg font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer"
  >
    Submit
  </button>

  <p
    id="contact-status"
    class="text-sm min-h-[1.25rem] text-muted"
    aria-live="polite"
    role="status"
  >
  </p>
</form>

<script>
  import '../scripts/contactForm.ts';
</script>
