---
import CodeRain from './CodeRain.astro';

const items = [
  {
    title: 'Full-Stack Web Development',
    description:
      'End-to-end web applications built with React, Next.js, and Node.js — from frontend to database.',
    icon: 'code',
  },
  {
    title: 'Backend & API Development',
    description:
      'Scalable REST and GraphQL APIs, robust database design, and server-side architecture.',
    icon: 'database',
  },
  {
    title: 'AI Integration',
    description:
      'Embedding AI-powered features and intelligent workflows into business applications.',
    icon: 'sparkles',
  },
  {
    title: 'Cloud Deployment & DevOps',
    description:
      'Reliable hosting, CI/CD pipelines, and infrastructure setup on Vercel, AWS, and Docker.',
    icon: 'cloud',
  },
];
---

<section data-fade-in class="relative py-12 sm:py-16 overflow-hidden">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <div>
        <p class="text-accent text-xs sm:text-sm font-medium tracking-[0.2em] uppercase mb-5">
          Capabilities
        </p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.05] tracking-tight">
          What I do?
        </h2>
      </div>

      <div class="relative">
        <CodeRain class="absolute inset-0 opacity-[0.10] pointer-events-none" />
        <div class="relative space-y-3">
        {
          items.map((item, i) => (
            <div
              class="accordion-item rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-sm overflow-hidden"
              data-open="false"
            >
              <button
                type="button"
                class="accordion-trigger w-full flex items-center gap-4 p-5 sm:p-6 text-left group cursor-pointer"
                aria-expanded="false"
                aria-controls={`acc-content-${i}`}
              >
                <span class="shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-white/[0.04] border border-white/10 text-accent group-hover:border-white/20 transition-colors">
                  {item.icon === 'code' && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="16 18 22 12 16 6" />
                      <polyline points="8 6 2 12 8 18" />
                    </svg>
                  )}
                  {item.icon === 'database' && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <ellipse cx="12" cy="5" rx="9" ry="3" />
                      <path d="M3 5v14a9 3 0 0 0 18 0V5" />
                      <path d="M3 12a9 3 0 0 0 18 0" />
                    </svg>
                  )}
                  {item.icon === 'sparkles' && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" />
                      <path d="M20 3v4" />
                      <path d="M22 5h-4" />
                      <path d="M4 17v2" />
                      <path d="M5 18H3" />
                    </svg>
                  )}
                  {item.icon === 'cloud' && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M17.5 19a4.5 4.5 0 1 0-1.41-8.775 5.5 5.5 0 0 0-10.787 2A4.5 4.5 0 0 0 6.5 19z" />
                    </svg>
                  )}
                </span>

                <span class="flex-1 font-display text-lg sm:text-xl font-semibold tracking-tight">
                  {item.title}
                </span>

                <svg
                  class="accordion-chevron shrink-0 h-5 w-5 text-muted transition-transform"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </button>

              <div id={`acc-content-${i}`} class="accordion-content">
                <div class="accordion-inner">
                  <p class="text-muted leading-relaxed pr-5 sm:pr-6 pb-5 sm:pb-6 pl-[4.75rem] sm:pl-[5rem]">
                    {item.description}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .accordion-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .accordion-item[data-open='true'] .accordion-content {
    grid-template-rows: 1fr;
  }
  .accordion-inner {
    overflow: hidden;
  }
  .accordion-item[data-open='true'] .accordion-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  import '../scripts/accordion.ts';
</script>
