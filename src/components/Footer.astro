---
const year = new Date().getFullYear();
const githubUrl = 'https://github.com/DinovLazar';
const emailUrl = 'mailto:dinovlazar2011@gmail.com';
---

<footer class="border-t border-white/5 mt-32">
  <div class="mx-auto max-w-6xl px-6 py-10 sm:py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 items-center gap-8">
      <div class="flex items-center justify-center md:justify-start gap-3 flex-wrap">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile"
          class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-white/[0.04] border border-white/10 text-fg hover:text-accent hover:border-white/20 hover:bg-white/[0.08] transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
        </a>

        <a
          href={emailUrl}
          aria-label="Email Lazar"
          class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-white/[0.04] border border-white/10 text-fg hover:text-accent hover:border-white/20 hover:bg-white/[0.08] transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
        </a>

        <button
          id="likes-button"
          type="button"
          aria-label="Like this site"
          class="inline-flex items-center gap-2 h-10 px-4 rounded-full bg-white/[0.04] border border-white/10 text-sm font-medium text-fg hover:bg-white/[0.08] hover:border-white/20 transition-colors cursor-pointer"
        >
          <svg
            class="h-4 w-4 text-accent"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M19.5 13.572 12 21l-7.5-7.428A5 5 0 1 1 12 6.006a5 5 0 1 1 7.5 7.566Z"
            />
          </svg>
          <span><span data-likes-count>0</span> Likes</span>
        </button>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 text-sm text-muted">
        <span class="inline-flex items-center gap-2">
          <span>Built with</span>
          <img
            src="https://cdn.simpleicons.org/astro/ffffff"
            alt=""
            decoding="async"
            width="16"
            height="16"
            class="h-4 w-4"
            aria-hidden="true"
          />
          <span class="text-fg">Astro</span>
        </span>
        <span class="inline-flex items-center gap-2">
          <span>Styled with</span>
          <img
            src="https://cdn.simpleicons.org/tailwindcss/06B6D4"
            alt=""
            decoding="async"
            width="16"
            height="16"
            class="h-4 w-4"
            aria-hidden="true"
          />
          <span class="text-fg">TailwindCSS</span>
        </span>
        <span class="inline-flex items-center gap-2">
          <span>Deployed on</span>
          <img
            src="https://cdn.simpleicons.org/vercel/ffffff"
            alt=""
            decoding="async"
            width="16"
            height="16"
            class="h-4 w-4"
            aria-hidden="true"
          />
          <span class="text-fg">Vercel</span>
        </span>
      </div>

      <div class="hidden md:block"></div>
    </div>

    <p class="mt-8 sm:mt-10 pt-6 border-t border-white/5 text-center text-xs text-muted">
      Copyright &copy; {year} Lazar Dinov. All rights reserved.
    </p>
  </div>
</footer>

<script>
  import '../scripts/likes.ts';
</script>
